<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Full movement speed for cargo holds -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[starts-with(defName, "jdgg_")]/pathCost</xpath>
        <value>
           <pathCost>0</pathCost>
        </value>
    </Operation>

    <!-- Change 5x5 DynaVac cargo hold to 3x3 -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="jdgg_XMCHVB"]/size</xpath>
        <value>
           <size>(3,3)</size>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="jdgg_XMCHVB"]/comps/li[@Class="CompProperties_Glower"]/glowRadius</xpath>
        <value>
           <glowRadius>3</glowRadius>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="jdgg_XMCHVB"]/graphicData/drawSize</xpath>
        <value>
            <drawSize>(3.48,3.48)</drawSize>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/AdaptiveStorage.GraphicsDef[defName="XMCHVacSteelGraphics" or defName="XMCHVacGoldGraphics" or defName="XMCHVacPlasteelGraphics" or defName="XMCHVacSilverGraphics" or defName="XMCHVacBarrierGraphics"]/graphics/li/graphicData/drawSize</xpath>
        <value>
           <drawSize>(3.48,3.48)</drawSize>
        </value>
    </Operation>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/AdaptiveStorage.GraphicsDef[defName="XMCHVacSteelGraphics" or defName="XMCHVacGoldGraphics" or defName="XMCHVacPlasteelGraphics" or defName="XMCHVacSilverGraphics" or defName="XMCHVacBarrierGraphics"]/graphics/li/graphicDatas/li/drawSize</xpath>
        <value>
           <drawSize>(3.48,3.48)</drawSize>
        </value>
    </Operation>

    <!-- Allow standing on it -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="jdgg_XMCHVB"]/passability</xpath>
        <value>
           <passability>Standable</passability>
        </value>
    </Operation>

    <!-- Ignore beauty of stored items -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="jdgg_XMCHVB"]/building/ignoreStoredThingsBeauty</xpath>
        <value>
           <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
        </value>
    </Operation>

    <!-- Compensate for reduced size -->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="jdgg_XMCHVB"]/building/maxItemsInCell</xpath>
        <value>
           <maxItemsInCell>9</maxItemsInCell>
        </value>
    </Operation>
</Patch>