<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Wall Mounted Turrets Version 2</li>
        </mods>
        <match Class="PatchOperationReplace">
            <!-- Fix wall foam turret so it actually works -->
            <xpath>Defs/ThingDef[defName="WallFoamTurret"]/thingClass</xpath>
            <value>
                <thingClass>Building_TurretFoam</thingClass>
            </value>
        </match>
    </Operation>
</Patch>